# Spring profile
SPRING_PROFILES_ACTIVE=prod

# Domain
API_DOMAIN=api.atma.biz.id
CORS_ALLOWED_ORIGINS=https://www.atma.biz.id
NGINX_CONF_FILE=./nginx/atma-api.conf
NGINX_CERT_DIR=./nginx/certs

# JWT
JWT_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef
JWT_EXPIRATION_MS=86400000
INTERNAL_SERVICE_TOKEN=internal-token-0123456789abcdef0123456789abcdef

# RDS MySQL
DB_HOST=atma-db.example.rds.amazonaws.com
DB_PORT=3306
DB_NAME=atma_dryer
DB_USERNAME=atma_app
DB_PASSWORD=db-password-0123456789abcdef

# Eureka
EUREKA_SERVER_URL=http://eureka_server:8761/eureka

# Backend ports internal
API_GATEWAY_PORT=8085
AUTH_SERVICE_PORT=8081
SENSOR_SERVICE_PORT=8082
EUREKA_SERVER_PORT=8761

# MQTT internal backend-to-broker traffic uses the private Docker listener.
# ESP32 devices use MQTT_BROKER_HOSTNAME:8883 with TLS.
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=sensor_service
MQTT_PASSWORD=mqtt-password-0123456789abcdef
MQTT_USE_TLS=false
MQTT_TLS_CA_FILE=/opt/atma/mosquitto/certs/ca.crt
MQTT_TLS_CERT_FILE=/opt/atma/mosquitto/certs/server.crt
MQTT_TLS_KEY_FILE=/opt/atma/mosquitto/certs/server.key
MQTT_CERT_DIR=/opt/atma/mosquitto/certs
MQTT_BROKER_HOSTNAME=mqtt.atma.biz.id
MQTT_PUBLIC_PORT=8883
MQTT_CLIENT_ID=sensor_service
MQTT_COMMAND_CLIENT_ID=sensor_service-command
MQTT_SENSOR_TOPIC=atma/device/atma-dryer-001/telemetry
MQTT_COMMAND_TOPIC_PREFIX=atma/device

# Device
DEVICE_ID=atma-dryer-001
DEVICE_OFFLINE_THRESHOLD_SECONDS=60
NOTIFICATION_TEMPERATURE_IDEAL_MIN=50.0
NOTIFICATION_TEMPERATURE_IDEAL_MAX=55.0
NOTIFICATION_HUMIDITY_THRESHOLD=70.0
NOTIFICATION_EVENT_COOLDOWN_SECONDS=300

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=grafana-password-0123456789abcdef

# SMTP / Brevo
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=smtp-user
MAIL_PASSWORD=smtp-password-0123456789abcdef
MAIL_FROM=noreply@atma.biz.id
MAIL_FROM_NAME=ATMA Dryer
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_SMTP_STARTTLS_REQUIRED=true
PASSWORD_RESET_CODE_TTL_MINUTES=10
PASSWORD_RESET_MAX_ATTEMPTS=5
PASSWORD_RESET_REQUEST_COOLDOWN_SECONDS=60
PASSWORD_RESET_SESSION_TTL_MINUTES=10

# Actuator / Metrics
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,prometheus
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=when_authorized
